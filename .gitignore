# 🔹 Dependencias (pueden reinstalarse con npm/yarn)
node_modules/
.pnp/
.pnp.js

# 🔹 Testing y cobertura de código
coverage/

# 🔹 Builds y distribuciones (archivos generados en la compilación)
dist/
build/
out/  # Algunas configuraciones de Electron generan esta carpeta

# 🔹 Archivos de configuración local y credenciales API
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 🔹 Archivos de depuración y logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
debug.log

# 🔹 Archivos innecesarios de sistema (MacOS, Windows, Linux)
.DS_Store
Thumbs.db
*.swp  # Archivos temporales de Vim
*.swo
.idea/  # Configuración de JetBrains (WebStorm, PHPStorm)
.vscode/  # Configuración de Visual Studio Code

# 🔹 Electron y empaquetado de la aplicación
/dist/win-unpacked/
dist/mac/
dist/linux/
app.asar
app.asar.unpacked/
